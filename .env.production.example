# Production env template (do NOT commit real secrets).

DEBUG=0

# Generate a strong value:
# python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=change-me

ALLOWED_HOSTS=chennu.co,www.chennu.co
CSRF_TRUSTED_ORIGINS=https://chennu.co,https://www.chennu.co
SITE_URL=https://chennu.co

# Postgres (Coolify can create these for you)
POSTGRES_DB=consulting
POSTGRES_USER=consulting
POSTGRES_PASSWORD=change-me

# If using external DB set DATABASE_URL directly:
# DATABASE_URL=postgres://user:pass@host:5432/dbname

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TASK_ALWAYS_EAGER=0

# Web tuning
WEB_CONCURRENCY=2
WEB_TIMEOUT=120

