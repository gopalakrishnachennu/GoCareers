# Production env template (do NOT commit real secrets).

DEBUG=0

# Generate a strong value:
# python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=change-me

# Never leave empty — Django rejects all hosts → HTTP 400 "Bad Request".
ALLOWED_HOSTS=chennu.co,www.chennu.co
# Hostname from SITE_URL is auto-merged into ALLOWED_HOSTS if missing.
SITE_URL=https://chennu.co
# Trust X-Forwarded-Host / X-Forwarded-Proto (default true in settings). Set false only on a direct, non-proxied bind.
TRUST_PROXY_TLS=true
# If Coolify/Traefik still sends an internal Host name, add it here (comma-separated), e.g.:
# ADDITIONAL_ALLOWED_HOSTS=consulting-abc123.coolify.internal
CSRF_TRUSTED_ORIGINS=https://chennu.co,https://www.chennu.co

# Postgres (Coolify can create these for you)
POSTGRES_DB=consulting
POSTGRES_USER=consulting
POSTGRES_PASSWORD=change-me

# If using external DB set DATABASE_URL directly:
# DATABASE_URL=postgres://user:pass@host:5432/dbname

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TASK_ALWAYS_EAGER=0

# Web tuning
WEB_CONCURRENCY=2
WEB_TIMEOUT=120

